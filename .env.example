# App
APP_URL=http://localhost:3000
NODE_ENV=development
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-a-long-random-password
SESSION_SECRET=change-me-to-at-least-32-random-characters

# Database / Queue
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dy_inventory?schema=public
REDIS_URL=redis://localhost:6379

# Boss Logics
BOSS_LOGICS_ENDPOINT=https://portal.bosslogics.com/boss/lib/data/view/view?_fn=data&options=REPLACE_ME&_format=json&_a=dy.ads
BOSS_LOGICS_COOKIE=replace-with-current-boss-logics-cookie
BOSS_LOGICS_REFERER=https://portal.bosslogics.com/:dy.ads/main-navigation/products
BOSS_LOGICS_STATIC_BASE_URL=https://static.dy.cloud.bosslogics.com

# Shopify custom app
SHOPIFY_SHOP=your-shop.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_replace_me
SHOPIFY_API_VERSION=2026-04
SHOPIFY_VENDOR="David Yurman"
SHOPIFY_PRODUCT_STATUS=ACTIVE
SHOPIFY_OUT_OF_STOCK_STATUS=DRAFT
SHOPIFY_ARCHIVE_MISSING_AFTER_DAYS=7
SHOPIFY_SYNC_MEDIA=true
SHOPIFY_PUBLISH_ON_CREATE=false

# Sync behavior
SYNC_QUEUE_NAME=dy-shopify-sync
SYNC_CONCURRENCY=2
SYNC_CRON_ENABLED=false
SYNC_CRON=*/30 * * * *
SYNC_DEFAULT_DRY_RUN=true
SYNC_MAX_PRODUCTS_PER_RUN=0
SYNC_BATCH_DELAY_MS=250
ARCHIVE_OUT_OF_STOCK=false
